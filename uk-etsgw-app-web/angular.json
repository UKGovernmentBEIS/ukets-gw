{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "yarn"
  },
  "newProjectRoot": "projects",
  "projects": {
    "uk-etsgw-app-web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "etsgw",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/uk-etsgw-app-web",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/assets",
              {
                "glob": "**/*",
                "input": "./node_modules/govuk-frontend/dist/govuk/assets",
                "output": "/assets/"
              }
            ],
            "styles": [
              "src/styles.scss",
              "node_modules/dialog-polyfill/dialog-polyfill.css"
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["node_modules/govuk-frontend/dist/"]
            },
            "scripts": [],
            "allowedCommonJsDependencies": [
              "keycloak-js",
              "clean-deep",
              "crypto-js",
              "base64-js",
              "js-sha256",
              "google-libphonenumber"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "uk-etsgw-app-web:build:production"
            },
            "development": {
              "proxyConfig": "proxy.conf.json",
              "buildTarget": "uk-etsgw-app-web:build:development",
              "port": 4199
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "uk-etsgw-app-web:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": ["src/styles.scss"],
            "scripts": []
          }
        }
      }
    },
    "govuk-components": {
      "projectType": "library",
      "root": "projects/govuk-components",
      "sourceRoot": "projects/govuk-components/src",
      "prefix": "govuk",
      "schematics": {
        "@schematics/angular:component": {
          "inlineStyle": true,
          "inlineTemplate": true,
          "changeDetection": "OnPush"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/govuk-components/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/govuk-components/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/govuk-components/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "tsConfig": "projects/govuk-components/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/govuk-components/**/*.ts",
              "projects/govuk-components/**/*.html"
            ]
          }
        }
      }
    },
    "etsgw-api": {
      "projectType": "library",
      "root": "projects/etsgw-api",
      "sourceRoot": "projects/etsgw-api/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/etsgw-api/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/etsgw-api/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/etsgw-api/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/etsgw-api/**/*.ts"]
          }
        }
      }
    }
  }
}
