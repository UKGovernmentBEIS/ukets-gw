{
  "name": "uk-etsgw-app-web",
  "version": "0.0.0",
  "engines": {
    "node": "^18.18"
  },
  "scripts": {
    "postinstall": "node git-version.js && yarn prebuild",
    "ng": "ng",
    "start": "ng serve",
    "test:frontend": "jest --config ./src/jest.config.js --silent --logHeapUsage --workerIdleMemoryLimit=1GB",
    "test:frontend:watch": "jest --watch --config ./src/jest.config.js",
    "test:frontend:coverage": "jest --coverage --config ./src/jest.config.js",
    "test:app:coverage": "yarn prebuild && yarn run test:frontend:coverage",
    "test:app:watch": "yarn build:govuk-components && yarn run test:frontend:watch",
    "build:govuk-components": "ng build govuk-components",
    "build:etsgw-api": "ng build etsgw-api",
    "prebuild": "yarn build:govuk-components && yarn build:etsgw-api",
    "build": "ng build",
    "prebuild:production": "yarn build:govuk-components && yarn build:etsgw-api",
    "build:production": "ng build",
    "generate:barrels:api": "barrelsby -d projects/etsgw-api/src/lib/ -l all -D",
    "generate:prepare-swagger-file": "node update-swagger-file.js",
    "pregenerate:api": "yarn generate:prepare-swagger-file && openapi-generator-cli generate -i projects/etsgw-api/src/assets/swagger.yaml -o projects/etsgw-api/src/lib/ -g typescript-angular -c projects/etsgw-api/openapi-config.yaml --global-property supportingFiles=.openapi-generator-ignore",
    "generate:api": "openapi-generator-cli generate -i projects/etsgw-api/src/assets/swagger.yaml -o projects/etsgw-api/src/lib/ -g typescript-angular -c projects/etsgw-api/openapi-config.yaml --global-property skipFormModel=false",
    "postgenerate:api": "yarn generate:barrels:api && rimraf projects/etsgw-api/src/lib/.openapi-generator && yarn build:etsgw-api && ng lint --fix && pretty-quick",
    "analyze": "ng build --source-map --named-chunks && source-map-explorer dist/uk-etsgw-app-web/*.*.js",
    "lint": "ng lint",
    "sonar": "sonar-scanner",
    "sonar:local": "sonar-scanner -Dsonar.host.url=http://localhost:9000 -Dsonar.login=admin -Dsonar.password=admin"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "dialog-polyfill": "^0.5.6",
    "govuk-frontend": "^5.6.0",
    "immer": "^10.1.1",
    "jwt-decode": "^4.0.0",
    "keycloak-js": "26.2.3",
    "rxjs": "~7.8.0",
    "sonar-scanner": "^3.1.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-builders/jest": "^17.0.3",
    "@angular-devkit/build-angular": "^17.3.5",
    "@angular-eslint/builder": "^17.5.3",
    "@angular-eslint/eslint-plugin": "^17.5.3",
    "@angular-eslint/eslint-plugin-template": "^17.5.3",
    "@angular-eslint/schematics": "^17.5.3",
    "@angular-eslint/template-parser": "^17.5.3",
    "@angular/cli": "^17.3.5",
    "@angular/compiler-cli": "^17.3.0",
    "@openapitools/openapi-generator-cli": "^2.13.5",
    "@testing-library/angular": "^15.2.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^29.5.0",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "barrelsby": "^2.2.0",
    "conventional-changelog-cli": "^2.1.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unused-imports": "^3.1.0",
    "git-branch": "^2.0.1",
    "git-describe": "^4.1.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.0.3",
    "ng-packagr": "^17.2.1",
    "prettier": "^2.8.3",
    "pretty-quick": "^3.1.3",
    "typescript": "~5.4.2"
  }
}
